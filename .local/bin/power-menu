#!/usr/bin/env bash

theme_str='
window {
    width: 230px;
    height: 290px;
}

element {
    children: [element-text];
    padding: 8px 12px 8px 18px;
}

textbox-prompt-colon {
    expand:     false;
    str:        "𐓏";
    margin:     0px 0.3em 0em 0em;
    text-color: @red;
}

listview {
    lines: 5;
}
'

CHOICE=$(echo -e "󰐥  Shutdown\n󰜉  Reboot\n󰌾  Lock\n󰒲  Sleep\n󰍃  Log out" | \
    rofi -dmenu -i -p "" -theme-str "$theme_str")

case $CHOICE in
    *"Shutdown") systemctl poweroff ;;
    *"Reboot") systemctl reboot ;;
    *"Lock") swaylock -f ;;
    *"Sleep") systemctl suspend ;;
    *"Log out") mmsg -s -d quit ;;
    "") ;;
    *) exit 1 ;;
esac
